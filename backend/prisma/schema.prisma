// AdProfit — PostgreSQL schema (Phase 1 foundation)
// Sync: `npx prisma migrate dev` from backend/

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships WorkspaceMember[]
}

model Workspace {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  defaultCurrency String   @default("USD")
  timezone        String   @default("America/Los_Angeles")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members       WorkspaceMember[]
  connections   Connection[]
  syncJobs      SyncJob[]
  metaSyncLogs  MetaSyncLog[]
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model WorkspaceMember {
  id          String          @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole   @default(MEMBER)
  createdAt   DateTime        @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

enum ConnectionProvider {
  META_ADS
  WOOCOMMERCE
  SHOPIFY
}

enum ConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
  SYNCING
}

/// External integration (Meta user token encrypted at rest in `secretEncrypted`).
model Connection {
  id                String             @id @default(cuid())
  workspaceId       String
  provider          ConnectionProvider
  status            ConnectionStatus   @default(DISCONNECTED)
  displayLabel      String?
  externalRef       String?
  secretEncrypted   Bytes?
  tokenType         String?
  tokenExpiresAt    DateTime?
  currency          String?
  timezoneName      String?
  connectedAt       DateTime?
  lastSuccessSyncAt DateTime?
  lastError         String?            @db.Text
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  syncJobs     SyncJob[]
  metaSyncLogs MetaSyncLog[]

  @@unique([workspaceId, provider])
  @@index([workspaceId])
}

/// Append-only log for Meta sync attempts (campaign insights, etc.).
model MetaSyncLog {
  id               String    @id @default(cuid())
  workspaceId      String
  metaConnectionId String
  type             String    @default("CAMPAIGN_INSIGHTS")
  status           String
  startedAt        DateTime?
  finishedAt       DateTime?
  errorMessage     String?   @db.Text
  createdAt        DateTime  @default(now())

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connection Connection @relation(fields: [metaConnectionId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([metaConnectionId])
}

enum SyncJobType {
  FULL
  INCREMENTAL
  WEBHOOK
}

enum SyncJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

model SyncJob {
  id           String         @id @default(cuid())
  workspaceId  String
  connectionId String?
  jobType      SyncJobType
  status       SyncJobStatus  @default(PENDING)
  cursorBefore String?        @db.Text
  cursorAfter  String?        @db.Text
  errorPayload Json?
  rowCounts    Json?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime       @default(now())

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connection Connection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([connectionId])
}
