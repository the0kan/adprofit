# AdProfit API — copy to backend/.env (never commit .env)

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL connection string
# Example local: postgresql://postgres:postgres@localhost:5432/adprofit?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/adprofit?schema=public"

# JWT signing secret — use a long random string in production (e.g. openssl rand -base64 48)
JWT_SECRET="change-me-to-a-long-random-secret-at-least-16-chars"
JWT_EXPIRES_IN=7d
ADMIN_TOKEN=

# Encrypts Meta user access tokens at rest (AES-256-GCM). Required when NODE_ENV=production.
# In development, omitting this logs a warning and uses an insecure dev-only key.
TOKEN_ENCRYPTION_SECRET=

# Where Meta OAuth should send users after callback (no trailing slash).
FRONTEND_URL=https://okan-ozkan.eu

# Workspace for Meta connections when JWT/workspace middleware is not wired yet.
# DEFAULT_META_WORKSPACE_SLUG=adprofit-demo
# DEFAULT_META_WORKSPACE_ID=

# Allowed browser origins (comma-separated). Required for production with credentials/CORS.
# Production static site + local dev (adjust/remove localhost in production-only deploys).
CORS_ORIGIN=https://okan-ozkan.eu,http://localhost:5173,http://127.0.0.1:5173

# Optional: prisma/db seed overrides (see prisma/seed.js)
# SEED_DEMO_EMAIL=demo@adprofit.local
# SEED_DEMO_PASSWORD=Demo12345!
# SEED_DEMO_WORKSPACE_SLUG=adprofit-demo

# -----------------------------------------------------------------------------
# Meta (Facebook) Ads — OAuth app (Marketing API)
# -----------------------------------------------------------------------------
# Create an app at https://developers.facebook.com/ , add the Marketing API /
# Facebook Login products as needed, and copy credentials from the app dashboard.
# Never commit real secrets; use backend/.env locally and a secrets manager in production.
#
# META_APP_ID — App ID from the Meta developer app (Settings → Basic).
META_APP_ID=

# META_APP_SECRET — App Secret (confidential). Treat like a password; rotate if exposed.
META_APP_SECRET=

# META_REDIRECT_URI — Full URL Meta redirects to after OAuth (must match “Valid OAuth
# Redirect URIs” in the Meta app exactly, including scheme and path). For local API
# testing, add a separate entry such as http://localhost:3000/v1/integrations/meta/callback.
META_REDIRECT_URI=https://adprofit.onrender.com/v1/integrations/meta/callback

# META_API_VERSION — Graph API version used for Marketing API paths (e.g. v20.0).
META_API_VERSION=v20.0

# META_SCOPES — Space-separated OAuth scopes (Facebook Login dialog).
META_SCOPES=ads_read

# -----------------------------------------------------------------------------
# Stripe (billing placeholders)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
